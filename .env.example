# --- Required ---

# Random secret used to sign session JWTs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Base URL of your Nextcloud instance (no trailing slash).
NEXTCLOUD_URL=https://your-nextcloud.example.com

# --- Optional (defaults shown) ---

# Port the server listens on.
PORT=3001

# Socket.IO path. Must match the path configured in the reverse proxy and the Android app.
SOCKET_PATH=/socket.io

# Allowed CORS origin. Use * to allow all origins (fine for native mobile apps).
CORS_ORIGIN=*

# Absolute path to the SQLite database file.
# Default: romme.db in the server directory.
# DB_PATH=/var/lib/romme/romme.db
